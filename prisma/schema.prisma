generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Payment {
  id           String       @id @default(cuid())
  amount       Float
  status       String       @default("pending") // pending, paid, expired, cancelled
  pixId        String?      @unique
  mpPaymentId  String?      @unique // Mercado Pago payment ID
  qrCode       String?      // QR Code base64
  qrCodeText   String?      // Copia e cola Pix
  attempts     Int          @default(1)
  expiresAt    DateTime?    // Expiração do Pix
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  session      GameSession?
}

model GameSession {
  id         String   @id @default(cuid())
  paymentId  String   @unique
  payment    Payment  @relation(fields: [paymentId], references: [id])
  results    String   // JSON: boolean[]
  revealed   String   @default("[]") // JSON: number[]
  isWinner   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Config {
  id                String  @id @default("default")
  precoTentativa    Float   @default(2.50)
  custoPremio       Float   @default(50.00)
  lucroMinimo       Float   @default(20.00)
  probabilidade     Float   @default(0.10)
  modoManual        Boolean @default(false)
  forcarPremio      Boolean @default(false)
  jackpotAcumulado  Float   @default(0)      // Prêmio acumulado
  metaJackpot       Float   @default(500)    // Meta para liberar jackpot
  rtpTarget         Float   @default(0.70)    // % retorno ao jogador (0-1)
  sequenciaSemPremio Int    @default(0)      // Contador para controle
}

model AuditLog {
  id        String   @id @default(cuid())
  event     String
  data      String?
  ip        String?  // IP do usuário
  createdAt DateTime @default(now())
}

model Transaction {
  id          String   @id @default(cuid())
  type        String   // 'in' (entrada) ou 'out' (saída/prêmio)
  amount      Float
  description String?
  paymentId   String?
  createdAt   DateTime @default(now())
}
