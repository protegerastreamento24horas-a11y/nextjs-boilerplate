generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Payment {
  id           String       @id @default(cuid())
  amount       Float
  status       String       @default("pending") // pending, paid, expired, cancelled
  pixId        String?      @unique
  mpPaymentId  String?      @unique // Mercado Pago payment ID
  qrCode       String?      // QR Code base64
  qrCodeText   String?      // Copia e cola Pix
  attempts     Int          @default(1)
  expiresAt    DateTime?    // Expiração do Pix
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  session      GameSession?
  
  // Campos de cadastro do cliente
  name         String?      // Nome do cliente
  cpf          String?      // CPF do cliente
  whatsapp     String?      // WhatsApp do cliente
  
  // Campos de afiliado
  affiliateId  String?      // ID do afiliado que indicou
  affiliateCode String?     // Código usado na URL (?ref=CODE)
  
  @@index([affiliateId])
  @@index([cpf])
}

model GameSession {
  id         String   @id @default(cuid())
  paymentId  String   @unique
  payment    Payment  @relation(fields: [paymentId], references: [id])
  results    String   // JSON: boolean[]
  revealed   String   @default("[]") // JSON: number[]
  isWinner   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Config {
  id                String  @id @default("default")
  precoTentativa    Float   @default(2.50)
  custoPremio       Float   @default(50.00)
  lucroMinimo       Float   @default(20.00)
  probabilidade     Float   @default(0.10)
  modoManual        Boolean @default(false)
  forcarPremio      Boolean @default(false)
  jackpotAcumulado  Float   @default(0)      // Prêmio acumulado
  metaJackpot       Float   @default(500)    // Meta para liberar jackpot
  rtpTarget         Float   @default(0.70)    // % retorno ao jogador (0-1)
  sequenciaSemPremio Int    @default(0)      // Contador para controle
}

model AuditLog {
  id        String   @id @default(cuid())
  event     String
  data      String?
  ip        String?  // IP do usuário
  createdAt DateTime @default(now())
}

model Transaction {
  id          String   @id @default(cuid())
  type        String   // 'in' (entrada) ou 'out' (saída/prêmio)
  amount      Float
  description String?
  paymentId   String?
  createdAt   DateTime @default(now())
}

// ========== SISTEMA DE AFILIADOS ==========

model Affiliate {
  id               String              @id @default(cuid())
  code             String              @unique // Código único do afiliado (ex: MARIA123)
  name             String
  email            String              @unique
  phone            String?
  cpf              String?             @unique
  pixKey           String?             // Chave PIX para saques
  pixKeyType       String?             // Tipo: cpf, email, phone, random
  status           String              @default("pending") // pending, active, blocked
  commissionRate   Float               @default(10.0) // % comissão (padrão 10%)
  totalEarnings    Float               @default(0)
  pendingBalance   Float               @default(0)
  paidBalance      Float               @default(0)
  totalSales       Int                 @default(0)
  totalClicks      Int                 @default(0)
  conversions      Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  
  // Relações
  commissions    AffiliateCommission[]
  withdrawals    AffiliateWithdrawal[]
  clicks         AffiliateClick[]
}

model AffiliateCommission {
  id            String    @id @default(cuid())
  affiliateId   String
  affiliate     Affiliate @relation(fields: [affiliateId], references: [id])
  paymentId     String?   // Referência ao pagamento que gerou a comissão
  amount        Float     // Valor da venda
  commission    Float     // Valor da comissão calculada
  rate          Float     // Taxa aplicada (%)
  status        String    @default("pending") // pending, approved, paid, cancelled
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([affiliateId])
  @@index([status])
}

model AffiliateWithdrawal {
  id          String    @id @default(cuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])
  amount      Float
  status      String    @default("pending") // pending, approved, rejected, paid
  pixKey      String    // Chave PIX usada para o saque
  pixKeyType  String
  paidAt      DateTime?
  notes       String?   // Observações internas
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([affiliateId])
  @@index([status])
}

model AffiliateClick {
  id          String    @id @default(cuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])
  ip          String?   // IP do visitante
  userAgent   String?   // Navegador
  referrer    String?   // De onde veio o clique
  converted   Boolean   @default(false) // Se virou venda
  createdAt   DateTime  @default(now())
  
  @@index([affiliateId])
  @@index([createdAt])
}
